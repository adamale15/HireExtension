{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "baseUrl": ".",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "wxt": [
        "node_modules/.pnpm/wxt@0.19.29_@types+node@25.5.2_rollup@4.60.1/node_modules/wxt"
      ],
      "wxt/*": [
        "node_modules/.pnpm/wxt@0.19.29_@types+node@25.5.2_rollup@4.60.1/node_modules/wxt/*"
      ]
    }
  },
  "include": ["src", ".wxt"]
}
